# Database (Supabase Postgres — schema-per-tenant)
DATABASE_URL=postgresql://app_user:password@db.supabase.co:5432/carelink

# Supabase (used for Vault / secrets + API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Supabase Vault: name/identifier of the secret that holds PHI encryption key
SUPABASE_VAULT_SECRET_NAME=phi-encryption-key
SUPABASE_VAULT_ENDPOINT=https://vault.supabase.co

# JWT (RS256) — store key files in Railway/Vercel secrets or filesystem
JWT_PRIVATE_KEY_PATH=/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem
JWT_ACCESS_TTL=900
JWT_JWKS_URL=
REFRESH_TOKEN_HMAC_SECRET=change-me-in-prod
REFRESH_TOKEN_TTL_SECONDS=604800
REFRESH_TOKEN_TTL_DAYS=7
MAX_CONCURRENT_SESSIONS=3

# Vault / KMS (production)
# Provide either the PEM content via `JWT_VAULT_PEM` or a secure path via `JWT_VAULT_PEM_PATH`.
# Prefer storing the PEM in Vault/KMS and exposing via deployment secrets rather than committing files.
JWT_VAULT_PEM=
JWT_VAULT_PEM_PATH=/secrets/jwt_private.pem
JWT_VAULT_KID=
# JWKS allowlist (comma-separated hosts). If set, only these hosts will be accepted for `JWT_JWKS_URL`.
JWT_JWKS_HOST_ALLOWLIST=
# JWKS fetch timeouts (ms)
JWT_JWKS_CONNECT_TIMEOUT_MS=5000
JWT_JWKS_READ_TIMEOUT_MS=5000

# KMS / Sign-only provider (optional)
# If you have a KMS or signing service that performs remote signing, set the URL
# of the signing endpoint and the key id to use. The service should accept JSON
# { "key_id": "<id>", "signing_input": "<base64url>" } and return
# { "signature": "<base64url>" }.
JWT_KMS_SIGNING_URL=
JWT_KMS_KEY_ID=
JWT_KMS_PROVIDER=

# PHI encryption (Supabase Vault)
PHI_ENCRYPTION_KEY_ID=phi-encryption-key

# Kafka (Confluent Cloud)
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxxx.region.confluent.cloud:9092
KAFKA_SASL_USERNAME=your_confluent_api_key
KAFKA_SASL_PASSWORD=your_confluent_api_secret
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SECURITY_PROTOCOL=SASL_SSL

# Redis (Upstash — serverless)
REDIS_URL=rediss://:your_upstash_password@eu1.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://eu1-upstash-api.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Deployment / runtime
RAILWAY_ENV=development
RAILWAY_PROJECT_ID=your_project_id
# Secrets must be stored in Railway/Vercel environment variables — do NOT commit secrets

# App settings
APP_ENV=development
LOG_LEVEL=info

# Other (local fallbacks, commented)
# LOCAL_REDIS_URL=redis://localhost:6379/0
# LOCAL_KAFKA=localhost:9092
