# Database
DATABASE_URL=postgresql://app_user:password@localhost:5432/carelink

# JWT (RS256)
JWT_PRIVATE_KEY_PATH=/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem

# AWS / KMS (optional local emulator)
KMS_KEY_ARN=arn:aws:kms:region:123456:key/abcdef

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# App settings
APP_ENV=development
LOG_LEVEL=info

# Other
REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
